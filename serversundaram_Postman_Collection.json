{
  "info": {
    "name": "serversundaram API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Menu",
      "item": [
        {
          "name": "Get Menu",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8085/api/menu",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["api", "menu"]
            }
          }
        },
        {
          "name": "Add Menu Item",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Chicken Burger\",\n  \"description\": \"Delicious burger with cheese\",\n  \"price\": 12.99,\n  \"available\": true,\n  \"categoryId\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:8085/api/menu",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["api", "menu"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8085/api/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tableId\": 1,\n  \"items\": [\n    {\n      \"menuItemId\": 1,\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:8085/api/orders",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["api", "orders"]
            }
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "http://localhost:8085/api/orders/1/status?status=PREPARING",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8085",
              "path": ["api", "orders", "1", "status"],
              "query": [{"key": "status", "value": "PREPARING"}]
            }
          }
        }
      ]
    },
    {
      "name": "Tables",
